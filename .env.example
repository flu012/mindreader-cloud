# Server hosts
NEO4J_HOST=192.168.3.42
SQL_HOST=192.168.3.42

# Neo4j credentials
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# SQL Server credentials
SQL_USER=sa
SQL_PASSWORD=your-sql-password

# Security
JWT_KEY=your-jwt-key-at-least-32-chars
INTERNAL_SECRET=your-internal-secret

# LLM Provider for MindReader Express
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Embedder (defaults to LLM key if not set)
# EMBEDDER_API_KEY=
# EMBEDDER_BASE_URL=
# EMBEDDER_MODEL=text-embedding-3-small
# EMBEDDER_DIM=1536

# Environment
ASPNETCORE_ENVIRONMENT=Development
