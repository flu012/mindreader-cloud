# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# LLM Provider: openai | anthropic | dashscope
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Embedder Provider: openai | dashscope
EMBEDDER_PROVIDER=openai
EMBEDDER_API_KEY=
EMBEDDER_MODEL=text-embedding-3-small

# Optional
UI_PORT=18900
MINDREADER_CACHE=~/.mindreader/cache
# MINDGRAPH_PYTHON_PATH=  # Auto-detected from monorepo structure
